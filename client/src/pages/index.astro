---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Resume from "../components/Resume.astro";
import Blog from "../components/Blog.astro";
import Contact from "../components/Contact.astro";

const title = "Rupak Chaulagain — Making Stuff & Breaking Stuff";
const description = "Portfolio of Rupak Chaulagain: projects, blogs, and more. Explore my work, experience, and contact information.";
const canonical = "https://chaulagainrupak.com/";
---

<BaseLayout title={title} description={description} canonical={canonical}>
    <Hero />
    <About />
    <Projects />
    <Resume />
    <!-- <Blog /> -->
    <Contact />
</BaseLayout>