---
import { Image } from "astro:assets";

import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
// Compute reading time from text
function computeReadingTime(text = "") {
  const words = text.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

// Extract first-level heading from markdown as fallback title
function extractTitle(body = "") {
  const match = body.match(/^#\s+(.*)/m);
  return match ? match[1].trim() : "Untitled";
}

// Extract all links from markdown safely
function extractLinks(body = "") {
  if (!body) return [];
  const matches = [...body.matchAll(/\[.*?\]\((.*?)\)/g)];
  return matches.map((m) => m[1]);
}

// Normalize slug from title or frontmatter
// @ts-ignore
function getSlug(post) {
  if (post.data.slug && post.data.slug.trim() !== "") return post.data.slug;
  if (post.data.title)
    return post.data.title.toLowerCase().replace(/\s+/g, "-");
  return post.id.toLowerCase().replace(/\s+/g, "-");
}

// Generate static paths for blog posts
export async function getStaticPaths() {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return posts.map((post, index) => ({
    params: { id: encodeURIComponent(post.id) }, // encode spaces
    props: {
      post,
      next: index > 0 ? posts[index - 1] : null,
      prev: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

// Props from Astro
const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);

// Dynamic page content
const rawBody = post.body ?? "";
const title = post.data.title ?? extractTitle(rawBody);
const description = post.data.description ?? "";
const readingTime = computeReadingTime(rawBody);
const outgoingLinks = extractLinks(rawBody);
const slug = getSlug(post);
---

<BaseLayout
  title={title}
  description={description}
  canonical={`https://chaulagainrupak.com.np/logs/${post.id}`}
>
  <header
    class="relative w-full min-h-[30vh] md:min-h-[40vh] flex flex-col justify-end bg-[var(--bg-main)] bg-graph border-b-2 border-[var(--border-dark)] overflow-hidden"
    style="background-size: 40px 40px;"
  >
    {
      post.data.heroImage && (
        <div class="absolute inset-0 z-0">
          
          <Image
            src={post.data.heroImage}
            alt={title}
            class="w-full h-full object-cover brightness-90"
            inferSize
            sizes="100vw"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg-main)] to-transparent" />
        </div>
      )
    }
    <div class="relative z-10 px-6 lg:px-16 pb-12 w-full">
      <span
        class="font-serif text-[clamp(2rem,5vw,3.5rem)] md:text-[clamp(2.5rem,6vw,4.5rem)]
  text-[var(--text-main)] leading-[1.1] tracking-tight mb-4
  overflow-hidden
  break-words
  -webkit-box
  -webkit-line-clamp-3
  -webkit-box-orient-vertical
  max-h-[8rem] md:max-h-[12rem]"
      >
        {title}
    </span>
      <p
        class="font-serif italic text-lg md:text-2xl text-[var(--accent)] leading-tight max-w-4xl mb-8
  overflow-hidden
  break-words
  -webkit-box
  -webkit-line-clamp-2
  -webkit-box-orient-vertical
  max-h-[4rem] md:max-h-[5rem]"
      >
        {description}
      </p>
      <div
        class="flex items-center gap-6 font-mono text-[0.65rem] tracking-[0.3em] text-[var(--text-main)] uppercase font-bold"
      >
        <span>
          {
            post.data.pubDate.toLocaleDateString("en-US", {
              month: "long",
              day: "numeric",
              year: "numeric",
            })
          }
        </span>
        <span class="text-[var(--text-faint)] font-normal">·</span>
        <span>{readingTime} MIN READ</span>
      </div>
    </div>
  </header>

  <div
    class="bg-[var(--bg-main)] bg-dotted min-h-screen"
    style="background-size: 20px 20px;"
  >
    <div
      class="max-w-[1400px] mx-auto px-6 lg:px-16 py-20 grid grid-cols-1 lg:grid-cols-[350px_1fr] gap-12 lg:gap-24"
    >
      <aside>
        <div class="sticky top-24 space-y-16">
          <section>
            <div class="flex items-center gap-4 mb-8">
              <h3
                class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.3em] text-[var(--accent)] whitespace-nowrap"
              >
                On this page
              </h3>
              <div class="w-full h-[1px] bg-[var(--border-light)]"></div>
              <span
                class="font-mono text-[0.5rem] text-[var(--text-faint)] uppercase italic"
                >begin</span
              >
            </div>
            <ul class="space-y-5">
              {
                headings.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="text-[0.7rem] font-mono uppercase text-[var(--text-mid)] hover:text-[var(--accent)] flex items-start gap-2 transition-colors truncate"
                    >
                      <span class="text-[var(--text-faint)]">—</span>
                      {h.text}
                    </a>
                  </li>
                ))
              }
            </ul>
          </section>
        </div>
      </aside>

      <div class="max-w-3xl">
        <article class="markdown-body">
          <Content />
        </article>

        <div class="mt-32 pt-10 border-t border-[var(--border-dark)]">
          <nav
            class="flex justify-between font-mono text-[0.6rem] uppercase tracking-[0.3em] text-[var(--text-faint)]"
          >
            <div class="flex flex-col gap-2">
              <span>← Previous</span>
              {
                prev ? (
                  <a
                    href={`/logs/${prev.id}`}
                    class="text-[var(--text-main)] font-bold text-xs hover:text-[var(--accent)] max-w-[200px] truncate"
                  >
                    {prev.data.title}
                  </a>
                ) : (
                  <span>This is the first entry</span>
                )
              }
            </div>
            <div class="flex flex-col gap-2 text-right">
              <span>Next →</span>
              {
                next ? (
                  <a
                    href={`/logs/${next.id}`}
                    class="text-[var(--text-main)] font-bold text-xs hover:text-[var(--accent)] max-w-[200px] truncate"
                  >
                    {next.data.title}
                  </a>
                ) : (
                  <span>End of archive</span>
                )
              }
            </div>
          </nav>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .hero-clamp {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    word-break: break-word;
  }

  .bg-graph {
    background-image: var(--bg-graph);
  }
  html {
    scroll-behavior: smooth;
  }

  .markdown-body {
    font-family: var(--font-sans);
    color: var(--text-main);
    font-size: 1.25rem;
    line-height: 1.75;
  }
  .markdown-body > * + * {
    margin-top: 1.6rem;
  }

  .markdown-body h1 {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    line-height: 1.2;
    letter-spacing: -0.03em;
  }
  .markdown-body h2 {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    border-bottom: 1px solid var(--border-light);
    padding-bottom: 0.4rem;
  }
  .markdown-body h3 {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    font-weight: 700;
  }

  .markdown-body p {
    opacity: 0.9;
  }
  .markdown-body strong {
    font-weight: 700;
    color: var(--text-main);
  }
  .markdown-body em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--text-mid);
  }
  .markdown-body hr {
    border: none;
    border-top: 1px solid var(--border-light);
    margin: 4rem 0;
    opacity: 0.6;
  }
  .markdown-body blockquote {
    margin: 3rem 0;
    padding: 24px;
    border-left: 4px solid var(--accent);
    background: var(--bg-alt);
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--text-mid);
    font-size: 1.35rem;
  }

  .markdown-body a {
    color: var(--text-main);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }
  .markdown-body a:hover {
    background: var(--accent);
    color: white;
    text-decoration: none;
  }

  .markdown-body code {
    font-family: var(--font-mono);
    background: var(--bg-alt);
    color: var(--accent);
    padding: 0.2rem 0.4rem;
    font-size: 0.85em;
  }
  .markdown-body pre {
    background: var(--border-darker);
    padding: 2rem;
    margin: 3rem 0;
    overflow-x: auto;
    border-left: 6px solid var(--accent);
  }
  .markdown-body pre code {
    background: transparent;
    color: #e2e8f0;
    padding: 0;
  }

  .markdown-body ul,
  .markdown-body ol {
    padding-left: 0;
    margin: 2.5rem 0;
  }
  .markdown-body li {
    position: relative;
    padding-left: 2rem;
    margin-bottom: 0.8rem;
  }
  .markdown-body ul li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: bold;
  }
  .markdown-body ol {
    counter-reset: item;
  }
  .markdown-body ol li {
    counter-increment: item;
  }
  .markdown-body ol li::before {
    content: counter(item) ".";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .markdown-body img {
    width: 100%;
    margin: 3rem 0;
    border: 1px solid var(--border-light);
  }
  .markdown-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 3rem 0;
    font-size: 0.95rem;
  }
  .markdown-body th,
  .markdown-body td {
    border: 1px solid var(--border-light);
    padding: 0.75rem 1rem;
    text-align: left;
  }
  .markdown-body th {
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--text-mid);
    background: var(--bg-alt);
  }
</style>
