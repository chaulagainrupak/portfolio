---

const experience = [
  {
    title: "Assistant Web Developer Intern",
    org: "Curves N' Colors",
    date: "Jul – Sep 2025",
    desc: "Website improvements, UI/UX optimization, frontend performance work.",
  },
  {
    title: "Independent Developer",
    org: "Self-directed",
    date: "2022 – Present",
    desc: "Built and shipped Paper Guides, Hulak, Batasey, and several open-source tools.",
  },
];

const education = [
  { title: "BSc Computer Science", org: "Kathmandu University",    date: "2025 – 2029 (expected)" },
  { title: "A-Levels",             org: "Global College International", date: "2023 – 2025" },
  { title: "SEE",                  org: "Nepal Don Bosco School",  date: "2023" },
];
---

<section id="resume" class="bg-[var(--bg-main)] bg-dotted">

  <div class="px-6 lg:px-16 py-12">
    <div class="grid lg:grid-cols-2 gap-12 fade-in">

      <div>
        <div class="font-mono text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-[var(--accent)] mb-5 pb-2 border-b-2 border-[var(--accent)]">
          Experience
        </div>
        {experience.map((e) => (
          <div class="mb-6 pl-4 border-l-2 border-[var(--border-light)] transition-all duration-200 hover:border-[var(--accent)] hover:translate-x-1">
            <div class="font-semibold text-[0.95rem] text-[var(--text-main)] mb-0.5">{e.title}</div>
            <div class="font-mono text-[0.65rem] text-[var(--accent)] mb-0.5">{e.org}</div>
            <div class="font-mono text-[0.6rem] text-[var(--text-faint)] mb-1">{e.date}</div>
            {e.desc && <div class="text-sm text-[var(--text-faint)] leading-relaxed">{e.desc}</div>}
          </div>
        ))}
      </div>

      <div>
        <div class="font-mono text-[0.65rem] font-semibold tracking-[0.15em] uppercase text-[var(--accent)] mb-5 pb-2 border-b-2 border-[var(--accent)]">
          Education
        </div>
        {education.map((e) => (
          <div class="mb-6 pl-4 border-l-2 border-[var(--border-light)] transition-all duration-200 hover:border-[var(--accent)] hover:translate-x-1">
            <div class="font-semibold text-[0.95rem] text-[var(--text-main)] mb-0.5">{e.title}</div>
            <div class="font-mono text-[0.65rem] text-[var(--accent)] mb-0.5">{e.org}</div>
            <div class="font-mono text-[0.6rem] text-[var(--text-faint)]">{e.date}</div>
          </div>
        ))}
      </div>

    </div>

    <div class="mt-8">
      <a href="/resume" class="inline-block px-6 py-3 font-mono text-sm font-semibold uppercase tracking-wider text-white bg-[var(--accent)] border-2 border-[var(--accent)] transition-transform duration-300 transform hover:scale-[1.04] hover:-translate-y-1 hover:bg-[var(--text-main)] hover:border-[var(--text-main)]">
        Full CV / Resume →
      </a>
    </div>
  </div>
</section>