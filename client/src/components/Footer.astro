---
<footer class="border-t border-[var(--border-light)] bg-[var(--text-main)] text-[var(--white)] px-6 py-10">
  <div class="max-w-7xl mx-auto grid gap-8 md:grid-cols-4">

    <!-- Brand -->
    <div>
      <a href="/" class="text-lg font-bold font-serif transition hover:text-[var(--accent)]">
        C.Rupak
      </a>
      <p class="mt-2 text-sm opacity-80">
        making stuff & breaking stuff.
      </p>
    </div>

    <!-- Main Links -->
    <div class="flex flex-col space-y-2">
      <span class="text-sm uppercase opacity-60">Explore</span>
      <a href="/projects" class="hover:text-[var(--accent)] transition">Projects</a>
      <a href="/resume" class="hover:text-[var(--accent)] transition">Resume</a>
      <a href="/logs" class="hover:text-[var(--accent)] transition">"B-Log"</a>
      <a href="/gallery" class="hover:text-[var(--accent)] transition">Gallery</a>
      <a href="#contact" class="hover:text-[var(--accent)] transition">Contact</a>
    </div>

    <!-- Projects & Experiments -->
    <div class="flex flex-col space-y-2">
      <span class="text-sm uppercase opacity-60">Projects & Experiments</span>
      <a href="https://paperguides.org" target="_blank" class="hover:text-[var(--accent)] transition">Paper-Guides</a>
      <a href="https://hulak.app" target="_blank" class="hover:text-[var(--accent)] transition">Hulak</a>
      <a href="https://batasey.chaulagainrupak.com.np" target="_blank" class="hover:text-[var(--accent)] transition">Batasey</a>
      <a href="https://nbc.chaulagainrupak.com.np" target="_blank" class="hover:text-[var(--accent)] transition">NepalBookClub Tool</a>
      <a href="https://addons.mozilla.org/en-US/firefox/addon/tmkoc-randomizer/" target="_blank" class="hover:text-[var(--accent)] transition">TMKOC Randomizer</a>
      <a href="https://github.com/chaulagainrupak/kosync" target="_blank" class="hover:text-[var(--accent)] transition">KOSync API</a>
    </div>

    <!-- External Links / Socials -->
    <div class="flex flex-col space-y-2">
      <span class="text-sm uppercase opacity-60">Elsewhere</span>
      <a href="https://github.com/chaulagainrupak" target="_blank" class="hover:text-[var(--accent)] transition">GitHub</a>
      <a href="https://www.linkedin.com/in/chaulagainrupak" target="_blank" class="hover:text-[var(--accent)] transition">LinkedIn</a>
      <a href="https://chaulagainrupak.com.np" target="_blank" class="hover:text-[var(--accent)] transition">chaulagainrupak.com.np</a>
      <a href="https://links.paperguides.org" target="_blank" class="hover:text-[var(--accent)] transition">PaperGuides Linktree</a>
      <a href="https://github.com/chaulagainrupak/paper-guides" target="_blank" class="hover:text-[var(--accent)] transition">PaperGuides GitHub</a>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="mt-10 pt-6 border-t border-[var(--border-light)] text-center text-sm opacity-70">
    © 2026 C.Rupak. All rights reserved.
  </div>
</footer>